#!/bin/bash
# This file is managed by Puppet, do not edit!
# Commands pulled from https://ondemand.xdmod.org/10.5/usage.html

set -e

BASE_CMD="xdmod-ondemand-ingestor"

RESOURCE="$1"
LOG_DIRECTORY="$2"
if [ "x${RESOURCE}" != "x" -a "x${LOG_DIRECTORY}" != "x" ]; then
  $BASE_CMD -d $LOG_DIRECTORY -r $RESOURCE
else
<% scope['xdmod::ondemand_resources'].each do |resource| -%>
  <%- next if resource['shred_directory'].nil? -%>
  $BASE_CMD -d <%= resource['shred_directory'] %> -r <%= resource['resource'] %>
<%- end -%>
fi
